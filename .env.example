# Vendure Shop API (required for catalog, checkout, account)
NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://gastro-backend.cap.aibestwriter.com/shop-api
# Optional server-only URL (SSR / API routes). Use internal Docker URL in production if needed.
VENDURE_SHOP_API_URL=https://gastro-backend.cap.aibestwriter.com/shop-api
# Must match the active channel token in backend/.env
VENDURE_CHANNEL_TOKEN=M8qW3nX6rT1yC9kL5vB2pD7sF4hJ0uN8gR6xQ1mZ3t

# Shop API cache seconds (0 = always fresh; default 0 in dev, 60 in production)
# VENDURE_SHOP_CACHE_SECONDS=0

NEXT_PUBLIC_SITE_URL=https://tecnox-store-frontend.cap.aibestwriter.com/

# Checkout: skip payment step in dev when using Vendure dummy handler
# NEXT_PUBLIC_VENDURE_CHECKOUT_SKIP_PAYMENT=true

# Optional: admin API for customer email lookup (password reset)
# VENDURE_ADMIN_API_URL=http://localhost:3000/admin-api
# VENDURE_ADMIN_USERNAME=superadmin
# VENDURE_ADMIN_PASSWORD=superadmin

# SMTP (order emails, password reset, contact form)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# FRONTEND_OTP_SECRET=change-me-in-production
