# ---------------------------------------------------------------------------
# Vendor (Vendure) Shop API — set per machine / environment (CI, staging, prod).
# Do not commit real secrets or production URLs in this file — copy to `.env.local`.
#
# Required: Full GraphQL endpoint URL (scheme, host, port if non-standard, path).
# Port and host MUST match wherever the vendor server is deployed.
# Documentation examples — replace with real deployment values!
# NEXT_PUBLIC_VENDURE_SHOP_API_URL={PROTOCOL}://{HOST}:{PORT}/shop-api
# ---------------------------------------------------------------------------

NEXT_PUBLIC_VENDURE_SHOP_API_URL=

# Channel identity for Shop requests (recommended server-side; avoid exposing publicly if unused client-side).
VENDURE_CHANNEL_TOKEN=

# Optional alternative if you deliberately need channel token client-side:
# NEXT_PUBLIC_VENDURE_CHANNEL_TOKEN=

# If "true", storefront checkout finishes at ArrangingPayment without addPaymentToOrder (manual/Admin flow).
# NEXT_PUBLIC_VENDURE_CHECKOUT_SKIP_PAYMENT=
